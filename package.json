{
    "name":  "file-organizer",
    "version":  "1.0.0",
    "description":  "Organizador de carpetas con UI",
    "main":  "electron/main.cjs",
    "scripts":  {
                    "dev":  "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
                    "dev:vite":  "vite",
                    "dev:electron":  "wait-on http://localhost:5173 \u0026\u0026 cross-env NODE_ENV=development electron .",
                    "build":  "vite build \u0026\u0026 electron-builder",
                    "build:vite":  "vite build"
                },
    "build":  {
                  "appId":  "com.alan.file-organizer",
                  "productName":  "File Organizer",
                  "directories":  {
                                      "output":  "dist-exe"
                                  },
                  "files":  [
                                "dist/**/*",
                                "electron/**/*"
                            ],
                  "win":  {
                              "target":  "nsis",
                              "icon":  "public/icon.ico"
                          },
                  "nsis":  {
                               "oneClick":  false,
                               "allowToChangeInstallationDirectory":  true
                           }
              },
    "devDependencies":  {
                            "@types/react":  "^19.1.5",
                            "@types/react-dom":  "^19.1.5",
                            "@vitejs/plugin-react":  "^4.5.2",
                            "concurrently":  "^9.1.2",
                            "cross-env":  "^7.0.3",
                            "electron":  "^36.4.0",
                            "electron-builder":  "^26.0.12",
                            "tailwindcss":  "^4.1.8",
                            "@tailwindcss/vite":  "^4.1.8",
                            "typescript":  "~5.8.3",
                            "vite":  "^6.3.5",
                            "wait-on":  "^8.0.3"
                        },
    "dependencies":  {
                         "lucide-react":  "^0.511.0",
                         "react":  "^19.1.0",
                         "react-dom":  "^19.1.0"
                     }
}
